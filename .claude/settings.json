{
  "permissions": {
    "allow": [
      "Bash(cargo fmt:*)",
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo run:*)",
      "Bash(cargo tree:*)",
      "Bash(rustc --version)",
      "Bash(cargo --version)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt && cargo clippy --quiet"
          }
        ]
      }
    ]
  }
}
